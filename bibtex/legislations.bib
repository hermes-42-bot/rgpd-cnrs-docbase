  howpublished = {\url{https://eur-lex.europa.eu/eli/reg/2016/679/oj}},
  year         = {2016},
  note         = {Entrée en application le 25 mai 2018. Art. 9 (données sensibles, y compris génétiques) ; art. 89 (recherche scientifique).},
